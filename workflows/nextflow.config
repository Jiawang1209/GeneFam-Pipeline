params.config = null
params.groups = "configs/species_groups.yaml"
params.env_name = "GeneFamilyFlow"
params.python_bin = "python"
params.r_bin = "/usr/local/bin/R"
params.project_name = "GDSL_demo"
params.gene_family = "GDSL"
params.aligner = "mafft"
params.tree_builder = "fasttree"
params.mock_mvp = false
params.run_identification = false
params.run_duplication_retention = false
params.mock_external_tools = false
params.mock_evidence_dir = "tests/fixtures/mock_evidence"
params.meme_txt = "tests/fixtures/mock_evidence/meme.txt"
params.meme_time_limit = 300
params.meme_nmotifs = 10
params.meme_minw = 6
params.meme_maxw = 50
params.meme_maxsize = 10000000
params.standard_stop_after_family_candidates = false
params.use_hmmer = true
params.hmmer_two_pass = false
params.use_diamond = true
params.container_image = "genefam-pipeline:latest"
params.apptainer_image = "genefam-pipeline_latest.sif"
params.outdir = "results/mock_mvp"
params.preprocess_outdir = "results/00_preprocess"
params.hmmer_max_evalue = 1e-10
params.hmmer_min_bitscore = 50.0
params.hmmer_min_domain_coverage = 0.35
params.final_rule = "intersection"
params.duplicates = null
params.family_members = null
params.kaks_pairs = null
params.pangenome_classes = null
params.mcscanx_collinearity = null
params.kaks_results = null
params.mcscanx_cds_a = null
params.mcscanx_cds_b = null
params.mcscanx_self_dir = null
params.kaks_calculator_bin = "KaKs_Calculator"
params.hmmscan_bin = "hmmscan"
params.pfam_db = null
params.hmmscan_domtbl = null
params.pfam_confirm_hmm_id = null
params.events_config = "configs/wgd_events.brassicaceae.yaml"
params.expression_matrix = null
params.expression_metadata = null
params.run_promoter = false
params.run_promoter_cis = false
params.promoter_cis_elements = null
params.promoter_element_descriptions = null
params.promoter_upstream_bp = 2000
params.promoter_downstream_bp = 0
params.plantcare_records_per_file = 100
params.run_feature_summary = false
params.filtered_domains = null
params.run_mcscanx_circlize = false
params.mcscanx_execute_self = true
params.mcscanx_self_search_tool = "diamond"
params.syntenic_pairs = null
params.run_ppi = false
params.ppi_edges = null
params.ppi_nodes = null
params.ppi_reference_species = null
params.gene_family_species_order = null
params.ks_bins = "0.3,0.8,1.5"
params.wgd_event_args = "--event WGD_layer_1=alpha --event WGD_layer_2=beta --event WGD_layer_3=gamma --event WGD_layer_4=theta"

conda {
  enabled = true
}

process {
  executor = "local"
  errorStrategy = "terminate"
  conda = params.env_name
}

profiles {
  activated {
    conda.enabled = false
    process.conda = null
  }

  local {
    conda.enabled = true
    process.conda = params.env_name
  }

  docker {
    docker.enabled = true
    conda.enabled = false
    docker.runOptions = '-u $(id -u):$(id -g)'
    process.container = params.container_image
    process.conda = null
  }

  apptainer {
    apptainer.enabled = true
    conda.enabled = false
    apptainer.autoMounts = true
    process.container = params.apptainer_image
    process.conda = null
  }
}
